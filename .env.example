# Required for runtime
GMAIL_ENABLED=true
MY_EMAIL=your_email@gmail.com
LLM_API_KEY=your_openai_compatible_api_key
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_MODEL=gpt-4o-mini

# Dedicated embedding service
EMBEDDING_API_URL=https://your-embedding-endpoint/v1/embeddings
EMBEDDING_API_KEY=your_embedding_api_key
EMBEDDING_MODEL=bge-large-zh-v1.5
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_API_KEY_HEADER=Authorization
EMBEDDING_API_KEY_PREFIX=Bearer

# Gmail OAuth files
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Gmail polling behavior
GMAIL_INBOX_LOOKBACK_HOURS=8
GMAIL_DEFAULT_FETCH_LIMIT=50

# Knowledge base
KNOWLEDGE_SOURCE_PATH=data/agency.txt
KNOWLEDGE_DB_PATH=db
KNOWLEDGE_RETRIEVER_K=3

# Database
# Prefer DATABASE_URL if you already have a full connection string.
# The app will normalize `postgresql://` to the psycopg driver automatically.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/customer_support_copilot
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=customer_support_copilot
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres

# LangSmith
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=customer-support-copilot
LANGSMITH_ENDPOINT=https://api.smith.langchain.com

# API
API_HOST=0.0.0.0
API_PORT=8000
CORS_ALLOW_ORIGINS=*
API_TITLE=Customer Support Copilot API
API_VERSION=1.0
API_DESCRIPTION=Business API for the Customer Support Copilot ticket workflow

# Graph runtime
GRAPH_RECURSION_LIMIT=100
